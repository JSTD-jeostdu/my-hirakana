rules_version = '2';

// v2 동기화 기능: 6자리 코드 하나 = Firestore 문서 하나.
// 코드를 아는 사람만 정확히 그 문서를 get/create/update 할 수 있고,
// 컬렉션 목록 조회(list)와 삭제는 항상 막는다 (계정 시스템이 없는 대신
// "코드를 아는 것 = 접근 권한"이라는 단순한 모델 — 참고 앱과 동일한 방식).
service cloud.firestore {
  match /databases/{database}/documents {
    match /syncCodes/{code} {
      allow get: if code.matches('^[0-9]{6}$');
      allow list: if false;
      allow delete: if false;
      allow create, update: if code.matches('^[0-9]{6}$')
        && request.resource.data.keys().hasOnly(['data', 'updatedAt'])
        && request.resource.data.data is string
        && request.resource.data.data.size() < 900000
        && request.resource.data.updatedAt is timestamp;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
